datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Workspace {
  id            Int            @id @default(autoincrement())
  name          String
  slug          String         @unique
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?
  admins        Admin[]
  doctors       Doctor[]
  registrations Registration[]
  users         User[]
  tests         Test[]
}

model SuperAdmin {
  id        Int                 @id @default(autoincrement())
  name      String
  email     String              @unique
  password  String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  sessions  SuperAdminSession[]
}

model SuperAdminSession {
  id           Int        @id @default(autoincrement())
  superAdminId Int
  token        String     @unique @db.VarChar(500)
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime   @default(now())
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
}

model User {
  id                       Int           @id @default(autoincrement())
  name                     String
  email                    String        @unique
  password                 String?
  provider                 String        @default("credentials")
  googleId                 String?       @unique
  roleId                   Int           @default(2) // Default customer role
  isEmailVerified          Boolean       @default(false)
  isApproved               Boolean       @default(false)
  rejected                 Boolean       @default(false)
  verificationToken        String?       @db.VarChar(255)
  verificationTokenExpires DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  role                     UserRole      @relation(fields: [roleId], references: [id])
  sessions                 UserSession[]
  
  workspaceId              Int?
  workspace                Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserRole {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  users       User[]
  permissions UserRolePermission[]
}

model UserRolePermission {
  id         Int      @id @default(autoincrement())
  roleId     Int
  permission String
  role       UserRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

model Admin {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  password        String
  provider        String         @default("credentials")
  roleId          Int            @default(1) // Default admin role
  isEmailVerified Boolean        @default(true)
  isApproved      Boolean        @default(true)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  role            AdminRole      @relation(fields: [roleId], references: [id])
  sessions        AdminSession[]

  // PDF letterhead configurations
  framePdfUrl     String?        @db.VarChar(500)
  headerMargin    Int            @default(140)
  footerMargin    Int            @default(100)
  useFrameDefault Boolean        @default(true)

  workspaceId     Int?
  workspace       Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model AdminSession {
  id        Int      @id @default(autoincrement())
  adminId   Int
  token     String   @unique @db.VarChar(500)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model AdminRole {
  id          Int                    @id @default(autoincrement())
  name        String                 @unique
  isDeleted   Boolean                @default(false)
  deletedAt   DateTime?
  admins      Admin[]
  permissions AdminRolePermission[]
}

model AdminRolePermission {
  id         Int       @id @default(autoincrement())
  roleId     Int
  permission String
  role       AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

model Doctor {
  id                  Int            @id @default(autoincrement())
  name                String
  code                String?
  degree              String?
  address             String?
  clinicName          String?
  incentivePercent    Decimal        @db.Decimal(5, 2) @default(0.00)
  lastPaid            DateTime?
  registrations       Registration[] @relation("RefBy")
  secondRegistrations Registration[] @relation("SecondRef")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  workspaceId         Int?
  workspace           Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, code])
}

model Test {
  id            Int                @id @default(autoincrement())
  name          String
  code          String?
  price         Decimal            @db.Decimal(10, 2)
  isProcessed   Boolean            @default(false)
  registrations RegistrationTest[]
  parameters    TestParameter[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspaceId   Int?
  workspace     Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, code])
}

model Registration {
  id               Int                @id @default(autoincrement())
  billOn           String             @default("Patient Rate")
  mobileNo         String
  labId            String
  regNo            String
  date             DateTime           @default(now())
  title            String             // Mr., Mrs., Dr.
  name             String
  city             String             @default("-NA-")
  age              Float
  ageUnit          String             @default("Year") // Year, Month, Day
  gender           String             // Male, Female, Other
  refById          Int?
  refBy            Doctor?            @relation("RefBy", fields: [refById], references: [id])
  secondRefId      Int?
  secondRef        Doctor?            @relation("SecondRef", fields: [secondRefId], references: [id])
  remark           String?
  colType          String             @default("Camp")
  expRptDate       DateTime?
  sampleDate       DateTime?
  sampleNo         String?
  sampleBy         String             @default("-NA-")
  paymentMode      String             @default("Cash")
  paymentRefNo     String?
  totalAmount      Decimal            @db.Decimal(10, 2) @default(0.00)
  collectionCharge Decimal            @db.Decimal(10, 2) @default(0.00)
  discountPercent  Decimal            @db.Decimal(10, 2) @default(0.00)
  discountAmount   Decimal            @db.Decimal(10, 2) @default(0.00)
  receivedAmount   Decimal            @db.Decimal(10, 2) @default(0.00)
  dueAmount        Decimal            @db.Decimal(10, 2) @default(0.00)
  stickerCount     Int                @default(1)
  barcode          String?
  status           String             @default("Pending") // Pending, Completed
  tests            RegistrationTest[]
  results          PatientResult[]
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspaceId      Int?
  workspace        Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, labId])
  @@unique([workspaceId, regNo])
  @@index([date])
  @@index([mobileNo])
}

model RegistrationTest {
  registrationId Int
  testId         Int
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  test           Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  
  // Sample Management fields
  sampleStatus   String       @default("Pending") // Pending, Accepted, Rejected
  sampleBarcode  String?
  sampleRemark   String?
  sendTo         String       @default("-NA-")
  expense        Decimal      @db.Decimal(10, 2) @default(0.00)
  assessNo       String?
  pathologist    String       @default("-NA-")
  collectedBy    String       @default("-NA-")
  product        String       @default("-NA-")

  @@id([registrationId, testId])
}

model TestParameter {
  id                  Int             @id @default(autoincrement())
  testId              Int
  test                Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  name                String
  
  // Male reference values
  minValMale          Float?
  maxValMale          Float?
  normalRangeMale     String?
  
  // Female reference values
  minValFemale        Float?
  maxValFemale        Float?
  normalRangeFemale   String?
  
  // Baby/Child reference values
  minValBaby          Float?
  maxValBaby          Float?
  normalRangeBaby     String?

  // Fallback default range
  normalRangeDefault  String?
  unit                String?
  order               Int             @default(1)
  results             PatientResult[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model PatientResult {
  id              Int           @id @default(autoincrement())
  registrationId  Int
  registration    Registration  @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  testParameterId Int
  testParameter   TestParameter @relation(fields: [testParameterId], references: [id], onDelete: Cascade)
  value           String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([registrationId, testParameterId])
}

model Lead {
  id        Int      @id @default(autoincrement())
  contact   String   @unique
  type      String   // "email" or "mobile"
  createdAt DateTime @default(now())
}

